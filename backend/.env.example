DATABASE_URL=postgres://user:password@host:5432/rook
PORT=4000
GITHUB_WEBHOOK_SECRET=your_webhook_secret
# Optional: enables AI coach tips in rook stats
# OPENAI_API_KEY=sk-...
# Set to 1 if your PostgreSQL requires SSL (e.g., Supabase, Cloud SQL)
# PGSSL=1
# Public URL of the API (used for webhook registration)
# PUBLIC_API_URL=https://your-cloud-run-url.run.app/api
